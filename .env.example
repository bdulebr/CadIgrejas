# ========================================================
# CONFIGURAÇÕES DO AMBIENTE (VPS LINUX)
# ========================================================
# Este arquivo deve ser renomeado para .env no servidor
# NUNCA envie o arquivo .env real para o GitHub.
# ========================================================

# Chave secreta do Django (Gere uma nova no servidor)
SECRET_KEY=django-insecure-gere-uma-chave-longa-e-aleatoria-aqui

# Modo Debug (NUNCA ative em produção)
DEBUG=False

# Forçar uso de HTTPS no Django (Cookies Seguros)
USE_HTTPS=True

# Domínios Permitidos (Coloque o IP da VPS e o Domínio)
ALLOWED_HOSTS=localhost,127.0.0.1,intranet.pvenseada.org

# Origens Confiáveis para o CSRF (Sempre inclua https://)
CSRF_TRUSTED_ORIGINS=https://intranet.pvenseada.org,http://localhost:8000

# Base URL para PDFs e E-mails
BASE_URL=https://intranet.pvenseada.org

# ========================================================
# BANCO DE DADOS (POSTGRESQL)
# ========================================================
# Se você comentar a linha abaixo, o sistema usará o SQLite local (apenas para testes).
# Formato: postgres://USUARIO:SENHA@HOST:PORTA/NOME_DO_BANCO
DATABASE_URL=postgres://seu_usuario:sua_senha@localhost:5432/intranet_db

# ========================================================
# SERVIÇOS EXTERNOS
# ========================================================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=seu_email@gmail.com
EMAIL_PASSWORD=sua_senha_de_app_do_gmail

GEMINI_API_KEY=sua_chave_aqui
GDRIVE_FOLDER_ID=id_da_pasta_aqui
GCALENDAR_ID=primary
